// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth 必備模型 ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // 系統權限
  isAdmin       Boolean   @default(false) 
  isAllowed     Boolean   @default(true)  
  
  // 關聯設定
  accounts      Account[]
  sessions      Session[]
  wishes        Wish[]    
  ratings       Rating[]  

  // 多清單 (Multi-List) 關聯
  ownedLists    List[]    @relation("ListOwner")   // 自己建立嘅 Lists
  memberOf      List[]    @relation("ListMembers") // 有權限進入嘅 Lists (被邀請)
  adminOf       List[]    @relation("ListAdmins")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- 系統設定 ---

model SystemConfig {
  id           Int      @id @default(1)
  siteTitle    String   @default("CM98 List")
  browserTitle String   @default("CM98 List")
  categories   String   @default("Food,Entertainment,Other")
}

// --- 多清單系統模型 (Multi-tenant) ---

model List {
  id          String   @id @default(cuid())
  title       String   
  description String?
  categories  String   @default("Food,Entertainment,Other") 
  createdAt   DateTime @default(now())

  ownerId     String
  owner       User     @relation("ListOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members     User[]   @relation("ListMembers") // 呢個 List 允許入嚟嘅 Users
  admins        User[]    @relation("ListAdmins")
  wishes      Wish[]                            // 呢個 List 裡面嘅 Items
}

// --- 應用程式自訂模型 (Wishlist Items & Ratings) ---

model Wish {
  id          String   @id @default(cuid())
  category    String   
  description String
  notes       String?
  link        String?  
  isVisited   Boolean  @default(false) 
  isPrivate   Boolean  @default(false) 
  createdAt   DateTime @default(now()) 
  
  // 每一個項目都必須歸屬一個 List
  listId      String
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)

  // 記錄係邊個 User 加嘅
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratings     Rating[] 
}

model Rating {
  id        String   @id @default(cuid())
  score     Float
  comment   String?  @db.Text
  wishId    String
  userId    String
  createdAt DateTime @default(now())

  wish      Wish     @relation(fields: [wishId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([wishId, userId])
}